---
layout: layouts/base.njk
---

{# Product JSON-LD Schema #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "{{ product.name }}",
  "description": "{{ product.description | stripHtml | truncate(300) }}",
  {% if product.images.length > 0 %}
  "image": [{% for img in product.images %}"{{ img }}"{% if not loop.last %}, {% endif %}{% endfor %}],
  {% endif %}
  "brand": {
    "@type": "Brand",
    "name": "ASSA ABLOY"
  },
  "sku": "{{ product.itemid }}",
  {% if product.categories.length > 0 %}
  "category": "{{ product.categories[0].name }}",
  {% endif %}
  "offers": {
    "@type": "Offer",
    "availability": "{% if product.in_stock %}https://schema.org/InStock{% else %}https://schema.org/PreOrder{% endif %}",
    "seller": {
      "@type": "Organization",
      "name": "Monterey Bay Door"
    }
  },
  "manufacturer": {
    "@type": "Organization",
    "name": "ASSA ABLOY"
  }
}
</script>

{# Breadcrumb Schema #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://monterey-bay-door.vercel.app/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Shop",
      "item": "https://monterey-bay-door.vercel.app/shop/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "{{ product.name }}"
    }
  ]
}
</script>

<!-- Breadcrumbs -->
<nav class="pdp-breadcrumbs" aria-label="Breadcrumb">
    <div class="container">
        <ol class="breadcrumb">
            <li><a href="/">Home</a></li>
            <li><span class="breadcrumb-sep">/</span></li>
            <li><a href="/shop/">Catalog</a></li>
            {% for cat in product.categories %}
            <li><span class="breadcrumb-sep">/</span></li>
            <li><span>{{ cat.name }}</span></li>
            {% endfor %}
            <li><span class="breadcrumb-sep">/</span></li>
            <li><span class="breadcrumb-current">{{ product.name }}</span></li>
        </ol>
    </div>
</nav>

<!-- Product Detail -->
<section class="pdp-section">
    <div class="container">
        <div class="pdp-layout">

            <!-- Image Gallery -->
            <div class="pdp-gallery">
                {% if product.images.length > 0 %}
                <div class="pdp-main-image">
                    <img src="{{ product.images[0] }}" alt="{{ product.name }}" loading="lazy" id="productMainImg">
                </div>
                {% if product.images.length > 1 %}
                <div class="pdp-thumbnails">
                    {% for img in product.images %}
                    <button class="pdp-thumb {% if loop.first %}active{% endif %}" onclick="document.getElementById('productMainImg').src='{{ img }}'; document.querySelectorAll('.pdp-thumb').forEach(t=>t.classList.remove('active')); this.classList.add('active');">
                        <img src="{{ img }}" alt="{{ product.name }} - Image {{ loop.index }}" loading="lazy">
                    </button>
                    {% endfor %}
                </div>
                {% endif %}
                {% else %}
                <div class="pdp-main-image pdp-no-image">
                    <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    <p>No image available</p>
                </div>
                {% endif %}
            </div>

            <!-- Product Info -->
            <div class="pdp-info">
                {% if product.categories.length > 0 %}
                <div class="pdp-categories">
                    {% for cat in product.categories %}
                    <span class="pdp-category-tag">{{ cat.name }}</span>
                    {% endfor %}
                </div>
                {% endif %}

                <h1>{{ product.name }}</h1>

                {% if product.itemid %}
                <p class="pdp-sku">SKU: {{ product.itemid }}</p>
                {% endif %}

                <div class="pdp-stock">
                    {% if product.in_stock %}
                    <span class="pdp-stock-badge pdp-in-stock">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:0.35rem"><polyline points="20 6 9 17 4 12"/></svg>
                        In Stock
                    </span>
                    {% else %}
                    <span class="pdp-stock-badge pdp-quote-only">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:0.35rem"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        Contact for Availability &amp; Pricing
                    </span>
                    {% endif %}
                </div>

                {% if product.description %}
                <div class="pdp-short-desc">
                    {{ product.description | safe }}
                </div>
                {% endif %}

                <div class="pdp-actions">
                    <a href="/contact/?product={{ product.name | urlencode }}" class="btn btn-primary btn-lg">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:0.4rem"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        Request a Quote
                    </a>
                    <a href="/shop/" class="btn btn-secondary btn-lg">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:0.4rem"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                        Back to Catalog
                    </a>
                </div>

                <!-- Trust Signals -->
                <div class="pdp-trust">
                    <div class="pdp-trust-item">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        Authorized ASSA ABLOY / Dugmore &amp; Duncan Distributor
                    </div>
                    <div class="pdp-trust-item">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        Direct Vendor Pricing — No Middleman Markup
                    </div>
                    <div class="pdp-trust-item">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        Serving Central California Since 2007
                    </div>
                </div>
            </div>
        </div>

        <!-- Full Description -->
        {% if product.detailed_description %}
        <div class="pdp-details">
            <h2>Product Details</h2>
            <div class="pdp-details-content">
                {{ product.detailed_description | safe }}
            </div>
        </div>
        {% endif %}

        <!-- Back to catalog -->
        <div class="pdp-back">
            <a href="/shop/" class="btn btn-secondary">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:0.4rem"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                Browse All Products
            </a>
        </div>
    </div>
</section>
