---
layout: layouts/base.njk
---

<!-- Product Schema (JSON-LD) -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ product.name | dump | safe }},
    "description": {{ product.description | stripHtml | dump | safe }},
    "sku": {{ product.itemid | dump | safe }},
    "brand": {
        "@type": "Brand",
        "name": "ASSA ABLOY"
    },
    {% if product.images and product.images.length %}
    "image": [
        {% for img in product.images %}"{{ img }}"{% if not loop.last %}, {% endif %}{% endfor %}
    ],
    {% endif %}
    {% if product.categories and product.categories.length %}
    "category": "{{ product.categories[0].name }}",
    {% endif %}
    "offers": {
        "@type": "Offer",
        "url": "https://montereybayoor.com/products/{{ product | productSlug }}/",
        "priceCurrency": "USD",
        "availability": "{% if product.in_stock %}https://schema.org/InStock{% else %}https://schema.org/PreOrder{% endif %}",
        "seller": {
            "@type": "LocalBusiness",
            "name": "Monterey Bay Door",
            "url": "https://montereybayoor.com",
            "telephone": "(831) 555-0100"
        }
    }
}
</script>

<!-- Breadcrumbs -->
<section class="pdp-breadcrumbs">
    <div class="container">
        <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span class="breadcrumb-sep">/</span>
            <a href="/shop/">Shop</a>
            {% if product.categories and product.categories.length %}
            <span class="breadcrumb-sep">/</span>
            <a href="/shop/">{{ product.categories[0].name }}</a>
            {% endif %}
            <span class="breadcrumb-sep">/</span>
            <span class="breadcrumb-current">{{ product.name }}</span>
        </nav>
    </div>
</section>

<!-- Product Detail -->
<section class="section section-light pdp-section">
    <div class="container">
        <div class="pdp-layout">
            <!-- Image Gallery -->
            <div class="pdp-gallery">
                {% if product.images and product.images.length %}
                    <div class="pdp-main-image">
                        <img src="{{ product.images[0] }}" alt="{{ product.name }}" id="pdpMainImg" loading="eager">
                    </div>
                    {% if product.images.length > 1 %}
                    <div class="pdp-thumbnails">
                        {% for img in product.images %}
                        <button class="pdp-thumb{% if loop.first %} active{% endif %}" onclick="document.getElementById('pdpMainImg').src='{{ img }}';document.querySelectorAll('.pdp-thumb').forEach(function(t){t.classList.remove('active')});this.classList.add('active');">
                            <img src="{{ img }}" alt="{{ product.name }} - Image {{ loop.index }}" loading="lazy">
                        </button>
                        {% endfor %}
                    </div>
                    {% endif %}
                {% else %}
                    <div class="pdp-main-image pdp-no-image">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="80" height="80"><rect x="14" y="4" width="20" height="40" rx="2" stroke="#999" stroke-width="1.5" fill="none"/><circle cx="30" cy="24" r="3" stroke="#999" stroke-width="1.5" fill="none"/><line x1="30" y1="27" x2="30" y2="32" stroke="#999" stroke-width="1.5"/><rect x="18" y="10" width="12" height="4" rx="1" stroke="#999" stroke-width="1" fill="none"/></svg>
                    </div>
                {% endif %}
            </div>

            <!-- Product Info -->
            <div class="pdp-info">
                {% if product.categories and product.categories.length %}
                <div class="pdp-categories">
                    {% for cat in product.categories %}
                    <span class="pdp-category-tag">{{ cat.name }}</span>
                    {% endfor %}
                </div>
                {% endif %}

                <h1>{{ product.name }}</h1>

                {% if product.itemid %}
                <p class="pdp-sku">SKU: {{ product.itemid }}</p>
                {% endif %}

                <div class="pdp-stock">
                    {% if product.in_stock %}
                    <span class="pdp-stock-badge pdp-in-stock">In Stock</span>
                    {% else %}
                    <span class="pdp-stock-badge pdp-quote-only">Quote Required</span>
                    {% endif %}
                </div>

                {% if product.description %}
                <div class="pdp-short-desc">
                    {{ product.description | safe }}
                </div>
                {% endif %}

                <div class="pdp-actions">
                    <a href="/contact/" class="btn btn-primary btn-lg">Request Quote</a>
                    <a href="tel:(831)555-0100" class="btn btn-secondary btn-lg">Call (831) 555-0100</a>
                </div>

                <div class="pdp-trust">
                    <div class="pdp-trust-item">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        <span>Authorized ASSA ABLOY Distributor</span>
                    </div>
                    <div class="pdp-trust-item">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        <span>Expert Installation Available</span>
                    </div>
                    <div class="pdp-trust-item">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                        <span>Direct Vendor Pricing</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Detailed Description -->
        {% if product.detailed_description %}
        <div class="pdp-details">
            <h2>Product Details</h2>
            <div class="pdp-details-content">
                {{ product.detailed_description | safe }}
            </div>
        </div>
        {% endif %}

        <!-- Back to Catalog -->
        <div class="pdp-back">
            <a href="/shop/" class="btn btn-secondary">&larr; Back to Catalog</a>
        </div>
    </div>
</section>
