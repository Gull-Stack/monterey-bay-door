---
layout: layouts/base.njk
title: Leads
description: Monterey Bay Door leads dashboard.
eleventyExcludeFromCollections: true
---

<section class="section section-light" style="min-height: 70vh;">
    <div class="container" style="max-width: 1000px;">
        <div class="section-header">
            <h1 class="section-title">Leads</h1>
            <p class="section-subtitle">Every inquiry from mbdoor.com, most recent first.</p>
        </div>

        <!-- PIN gate -->
        <div id="pin-gate" class="card" style="display: none; max-width: 420px; margin: 0 auto;">
            <h3>Enter PIN</h3>
            <input type="tel" id="pin-input" inputmode="numeric" maxlength="8" placeholder="PIN"
                   style="width: 100%; padding: 0.9rem 1rem; font-size: 1.3rem; letter-spacing: 0.3em; text-align: center; border: 1px solid #ccc; border-radius: var(--border-radius); margin: 1rem 0;">
            <button id="pin-btn" class="btn btn-primary" style="width: 100%;">Unlock</button>
            <p id="pin-error" style="color: #b00020; display: none; margin-top: 0.75rem;">Wrong PIN — try again.</p>
        </div>

        <!-- Dashboard -->
        <div id="dash" style="display: none;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.75rem;">
                <p id="count" style="font-weight: 600; margin: 0;"></p>
                <button id="refresh" class="btn btn-secondary btn-sm">Refresh</button>
            </div>
            <div id="loading" style="display:none; color: var(--color-text-muted);">Loading leads…</div>
            <div id="empty" style="display:none; color: var(--color-text-muted);">No leads yet. New inquiries will show up here automatically.</div>
            <div style="overflow-x:auto;">
                <table id="leads-table" style="width:100%; border-collapse: collapse; display:none; font-size: 0.92rem;">
                    <thead>
                        <tr style="text-align:left; border-bottom: 2px solid #ddd;">
                            <th style="padding: 0.6rem 0.5rem;">Date</th>
                            <th style="padding: 0.6rem 0.5rem;">Name</th>
                            <th style="padding: 0.6rem 0.5rem;">Contact</th>
                            <th style="padding: 0.6rem 0.5rem;">Interest</th>
                            <th style="padding: 0.6rem 0.5rem;">Message</th>
                        </tr>
                    </thead>
                    <tbody id="leads-body"></tbody>
                </table>
            </div>
        </div>
    </div>
</section>

<script>
(function () {
  var API = '/api/leads';
  var gate = document.getElementById('pin-gate');
  var dash = document.getElementById('dash');
  var pinInput = document.getElementById('pin-input');
  var pinBtn = document.getElementById('pin-btn');
  var pinError = document.getElementById('pin-error');
  var pin = '';

  function show(el) { el.style.display = 'block'; }
  function hide(el) { el.style.display = 'none'; }

  function post(body) {
    return fetch(API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    }).then(function (r) {
      if (!r.ok) throw new Error(String(r.status));
      return r.json();
    });
  }

  function esc(s) {
    return String(s == null ? '' : s).replace(/[&<>"]/g, function (c) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c];
    });
  }

  function fmtDate(iso) {
    if (!iso) return '';
    var d = new Date(iso);
    if (isNaN(d)) return iso;
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) +
      ', ' + d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
  }

  function render(leads) {
    var body = document.getElementById('leads-body');
    var table = document.getElementById('leads-table');
    var empty = document.getElementById('empty');
    document.getElementById('count').textContent =
      leads.length + (leads.length === 1 ? ' lead' : ' leads');
    if (!leads.length) { hide(table); show(empty); return; }
    hide(empty);
    body.innerHTML = leads.map(function (l) {
      var contact = [];
      if (l.email) contact.push('<a href="mailto:' + esc(l.email) + '">' + esc(l.email) + '</a>');
      if (l.phone) contact.push('<a href="tel:' + esc(l.phone) + '">' + esc(l.phone) + '</a>');
      return '<tr style="border-bottom:1px solid #eee; vertical-align:top;">' +
        '<td style="padding:0.6rem 0.5rem; white-space:nowrap;">' + esc(fmtDate(l.created_at)) + '</td>' +
        '<td style="padding:0.6rem 0.5rem; font-weight:600;">' + esc(l.name) + '</td>' +
        '<td style="padding:0.6rem 0.5rem;">' + (contact.join('<br>') || '—') + '</td>' +
        '<td style="padding:0.6rem 0.5rem;">' + esc(l.interest || '—') + '</td>' +
        '<td style="padding:0.6rem 0.5rem; max-width:320px;">' + esc(l.message || '') + '</td>' +
        '</tr>';
    }).join('');
    table.style.display = 'table';
  }

  function loadLeads() {
    var loading = document.getElementById('loading');
    show(loading);
    post({ action: 'list', pin: pin }).then(function (res) {
      hide(loading);
      render(res.leads || []);
    }).catch(function () {
      hide(loading);
      document.getElementById('count').textContent = 'Could not load leads.';
    });
  }

  function unlock(p) {
    return post({ action: 'verify', pin: p }).then(function () {
      pin = p;
      try { sessionStorage.setItem('mbd_leads_pin', p); } catch (e) {}
      hide(gate); show(dash); loadLeads();
    });
  }

  var saved = '';
  try { saved = sessionStorage.getItem('mbd_leads_pin') || ''; } catch (e) {}
  if (saved) {
    unlock(saved).catch(function () { show(gate); });
  } else {
    show(gate);
  }

  pinBtn.addEventListener('click', function () {
    hide(pinError);
    unlock(pinInput.value.trim()).catch(function () { show(pinError); });
  });
  pinInput.addEventListener('keydown', function (e) { if (e.key === 'Enter') pinBtn.click(); });
  document.getElementById('refresh').addEventListener('click', loadLeads);
})();
</script>
