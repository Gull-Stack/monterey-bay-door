<!-- Scoped styles for projects page -->
<style>
    .featured-project {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--color-border);
        border-radius: var(--border-radius);
        overflow: hidden;
        margin-top: 2rem;
    }
    .featured-project-content {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        min-height: 400px;
    }
    .featured-project-image {
        background-image: linear-gradient(135deg, rgba(5, 30, 33, 0.3), rgba(5, 30, 33, 0.6)), url('/assets/images/hospitality/luxury-hotel-corridor-hallway-doors.jpg');
        background-size: cover;
        background-position: center;
        min-height: 300px;
        display: flex;
        align-items: flex-end;
        padding: 2rem;
    }
    .featured-project-badge {
        display: inline-block;
        background-color: var(--color-accent);
        color: var(--color-white);
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.1rem;
        text-transform: uppercase;
        padding: 0.35rem 0.75rem;
        border-radius: 4px;
    }
    .featured-project-details {
        padding: 3rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    .featured-project-details h3 {
        font-size: clamp(1.4rem, 2.5vw, 2rem);
        color: var(--color-white);
        margin-bottom: 0.5rem;
    }
    .featured-project-details .project-category {
        display: inline-block;
        color: var(--color-accent);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.1rem;
        text-transform: uppercase;
        margin-bottom: 1.25rem;
    }
    .featured-project-details p {
        color: var(--color-text-muted);
        margin-bottom: 1rem;
        font-size: 0.9rem;
        line-height: 1.7;
    }
    .featured-project-details .highlight-stat {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--color-accent);
        margin-bottom: 0.25rem;
    }
    .featured-project-details .highlight-label {
        color: var(--color-text-muted);
        font-size: 0.8rem;
        margin-bottom: 1.5rem;
    }
    .scope-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
    }
    .scope-tag {
        background: rgba(148, 171, 105, 0.15);
        color: var(--color-accent);
        font-size: 0.7rem;
        font-weight: 600;
        padding: 0.3rem 0.6rem;
        border-radius: 4px;
        border: 1px solid rgba(148, 171, 105, 0.3);
    }

    .project-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        margin-top: 2rem;
    }
    .project-card {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--color-border);
        border-radius: var(--border-radius);
        padding: 1.75rem;
        transition: var(--transition);
        display: flex;
        flex-direction: column;
    }
    .project-card:hover {
        transform: translateY(-4px);
        border-color: rgba(148, 171, 105, 0.4);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.3);
    }
    .project-card .project-category {
        display: inline-block;
        color: var(--color-accent);
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.1rem;
        text-transform: uppercase;
        margin-bottom: 0.75rem;
    }
    .project-card h3 {
        color: var(--color-white);
        font-size: 1.1rem;
        margin-bottom: 0.5rem;
    }
    .project-card p {
        color: var(--color-text-muted);
        font-size: 0.8rem;
        line-height: 1.6;
        flex-grow: 1;
    }
    .project-card .project-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--color-accent);
        text-decoration: none;
        font-size: 0.8rem;
        font-weight: 600;
        margin-top: 1rem;
        transition: var(--transition);
    }
    .project-card .project-link:hover {
        gap: 0.6rem;
    }
    .project-card .project-link svg {
        width: 14px;
        height: 14px;
        transition: var(--transition);
    }

    .category-heading {
        color: var(--color-accent);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.15rem;
        text-transform: uppercase;
        margin-top: 3rem;
        margin-bottom: 0.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--color-border);
    }

    @media (max-width: 768px) {
        .featured-project-content {
            grid-template-columns: 1fr;
        }
        .featured-project-details {
            padding: 2rem;
        }
        .project-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @media (max-width: 480px) {
        .project-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

